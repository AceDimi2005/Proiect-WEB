<section id="galerie-animata" class="galerie-animata-componenta">
    <h2>Galerie animata</h2>
    <p class="detalii-galerie-animata">
        La aceasta incarcare sunt afisate <strong><%= numarImaginiAnimata %></strong> imagini.
    </p>

    <% if (Array.isArray(celuleGalerieAnimata) && celuleGalerieAnimata.length > 0 && cssGalerieAnimata) { %>
        <style><%- cssGalerieAnimata %></style>

        <div class="fereastra-galerie-animata" role="region" aria-label="Galerie animata TechForge">
            <div class="pista-galerie-animata">
                <% celuleGalerieAnimata.forEach(function(celula) { %>
                    <% if (celula && celula.imagine) { %>
                        <% const imagine = celula.imagine; %>
                        <figure class="item-galerie-animata">
                            <picture>
                                <source srcset="<%= imagine.cale_mica %>" media="(max-width:700px)" />
                                <source srcset="<%= imagine.cale_medie %>" media="(max-width:1200px)" />
                                <img
                                    src="<%= imagine.cale_mare %>"
                                    alt="<%= imagine.alt %>"
                                    title="<%= imagine.text_descriere %>"
                                    loading="lazy" />
                            </picture>
                            <figcaption><%= imagine.titlu %></figcaption>
                        </figure>
                    <% } else { %>
                        <div class="item-galerie-animata celula-goala-animata" aria-hidden="true"></div>
                    <% } %>
                <% }); %>
            </div>
        </div>
    <% } else { %>
        <p class="fara-imagini-galerie-animata">Nu exista suficiente imagini marcate pentru galeria animata.</p>
    <% } %>
</section>
